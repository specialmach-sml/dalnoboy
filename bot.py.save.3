=====================================

async def init_db():
    global DB

    DB = await asyncpg.create_pool(DB_DSN)

    logger.info("✅ DB CONNECTED")

# ==================================================
# START
# ==================================================

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):

    text = (
        "🚛 UBER FREIGHT ONLINE\n\n"
        "КОМАНДЫ:\n"
        "/cargo - список грузов"
    )

    await update.effective_message.reply_text(text)

# ==================================================
# CARGO
# ==================================================

async def cargo(update: Update, context: ContextTypes.DEFAULT_TYPE):

    logger.info("🔥 /cargo CALLED")

    try:

        rows = await DB.fetch("""
            SELECT
                id,
                from_city,
                to_city,
                status
            FROM cargo
            ORDER BY id DESC
            LIMIT 10
        """)

        logger.info(f"📦 CARGO COUNT: {len(rows)}")

        if not rows:
            await update.effective_message.reply_text(
                "❌ Грузов нет"
            )
            return

        for r in rows:

            text = (
                f"📦 ГРУЗ #{r['id']}\n\n"
                f"🚩 {r['from_city']} → {r['to_city']}\n"
                f"📊 Статус: {r['status']}"
            )

            keyboard = InlineKeyboardMarkup([
                [
                    InlineKeyboardButton(
                        "🚛 ОТКЛИКНУТЬСЯ",
                        callback_data=f"cargo_{r['id']}"
                    )
                ]
            ])

            await update.effective_message.reply_text(
                text,
                reply_markup=keyboard
            )

    except Exception as e:

        logger.exception(e)

        await update.effective_message.reply_text(
            f"❌ ERROR:\n{e}"
        )

# ==================================================
# RESPONSE
# ==================================================

async def respond(update: Update, context: ContextTypes.DEFAULT_TYPE):

    try:

        q = update.callback_query

        await q.answer()

        logger.info(f"🔥 CALLBACK: {q.data}")

        cargo_id = int(q.data.split("_")[1])

        telegram_user = q.from_user

        user_id = telegram_user.id

        truck = await DB.fetchrow("""
            SELECT id
            FROM trucks
            WHERE driver_id=$1
            ORDER BY id DESC
            LIMIT 1
        """, user_id)

        if not truck:

            await q.edit_message_text(
                "❌ У вас нет машины"
            )

            return

        existing = await DB.fetchrow("""
            SELECT id
            FROM responses
            WHERE cargo_id=$1
            AND driver_id=$2
        """,
            cargo_id,
            user_id
        )

        if existing:

            await q.edit_message_text(
                "⚠️ Вы уже откликались"
            )

            return

        await DB.execute("""
            INSERT INTO responses (
                cargo_id,
                truck_id,
                driver_id,
                status,
                message
            )
            VALUES (
                $1,
                $2,
                $3,
                'pending',
                $4
            )
        """,
            cargo_id,
            truck["id"],
            user_id,
            f"Отклик от {telegram_user.full_name}"
        )

        await q.edit_message_text(
            "✅ Отклик отправлен"
        )

    except Exception as e:

        logger.exception(e)

        try:
            await update.callback_query.edit_message_text(
                f"❌ CALLBACK ERROR:\n{e}"
            )
        except:
            pass

# ==================================================
# MAIN
# ==================================================

async def post_init(app: Application):
    await init_db()

def main():

    app = (
        Application.builder()
        .token(TOKEN)
        .post_init(post_init)
        .build()
    )

    app.add_handler(
        CommandHandler("start", start)
    )

    app.add_handler(
        CommandHandler("cargo", cargo)
    )

    app.add_handler(
        CallbackQueryHandler(
            respond,
            pattern="cargo_"
        )
    )

    logger.info("🚛 BOT STARTED")

    app.run_polling()

# ==================================================
# START APP
# ==================================================

if __name__ == "__main__":
    main()
