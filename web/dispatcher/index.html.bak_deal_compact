async function saveClientNote(id){
  const el = document.getElementById("clientNoteText");
  const note = el ? el.value : "";

  const res = await fetch("/api/dispatcher/client/" + id + "/note", {
    method:"POST",
    headers:{ "Content-Type":"application/json" },
    body:JSON.stringify({ note })
  });

  const data = await res.json();

  if(!data.success){
    alert("Ошибка сохранения заметки");
    return;
  }

  const c = (window.clientItems || []).find(x => Number(x.id) === Number(id));
  if(c) c.note = note;

  alert("✅ Заметка сохранена");
}

async function setDealStatus(id,status){
  await fetch("/api/deal/"+id+"/status",{
    method:"POST",
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({status})
  });

  openDeal(id);
  location.reload();
}

