<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <title>Кабинет диспетчера — Dalnoboy</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
:root{
  --bg:#0f172a;
  --bg2:#111827;
  --panel:rgba(30,41,59,.78);
  --card:rgba(15,23,42,.82);
  --line:rgba(148,163,184,.22);

  --primary:#6366f1;
  --secondary:#8b5cf6;
  --electric:#38bdf8;

  --success:#22c55e;
  --warning:#f59e0b;
  --danger:#ef4444;

  --text:#f8fafc;
  --muted:#94a3b8;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:Inter,Arial,Helvetica,sans-serif;
  background:
    radial-gradient(circle at top left, rgba(99,102,241,.28), transparent 32%),
    radial-gradient(circle at top right, rgba(56,189,248,.18), transparent 28%),
    linear-gradient(135deg,#020617,#0f172a 45%,#111827);
  color:var(--text);
  min-height:100vh;
}

header{
  background:rgba(2,6,23,.74);
  backdrop-filter:blur(18px);
  color:white;
  padding:20px 28px;
  display:flex;
  align-items:center;
  gap:16px;
  border-bottom:1px solid rgba(148,163,184,.18);
  box-shadow:0 12px 35px rgba(0,0,0,.25);
}

header img{
  width:64px;
  height:64px;
  border-radius:20px;
  object-fit:cover;
  box-shadow:0 0 0 2px rgba(255,255,255,.08),0 16px 40px rgba(99,102,241,.35);
}

.wrap{
  padding:14px;
  max-width:1540px;
  margin:0 auto;
}

.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(190px,1fr));
  gap:18px;
  margin-bottom:26px;
}

.card{
  position:relative;
  overflow:hidden;
  background:linear-gradient(145deg,rgba(30,41,59,.9),rgba(15,23,42,.86));
  border:1px solid rgba(148,163,184,.18);
  border-radius:24px;
  padding:14px;
  box-shadow:0 22px 60px rgba(0,0,0,.22);
}

.card:before{
  content:"";
  position:absolute;
  inset:-1px;
  background:linear-gradient(135deg,rgba(99,102,241,.32),transparent 45%,rgba(56,189,248,.18));
  opacity:.55;
  pointer-events:none;
}

.card .num{
  position:relative;
  font-size:31px;
  font-weight:900;
  margin-top:11px;
  color:#fff;
  letter-spacing:-.04em;
}

h2{
  margin:32px 0 14px;
  font-size:22px;
  color:#fff;
  display:flex;
  align-items:center;
  gap:10px;
}

h2:after{
  content:"";
  height:1px;
  flex:1;
  background:linear-gradient(90deg,rgba(99,102,241,.8),transparent);
}

table{
  width:100%;
  border-collapse:separate;
  border-spacing:0;
  background:rgba(15,23,42,.72);
  border:1px solid rgba(148,163,184,.18);
  border-radius:24px;
  overflow:hidden;
  box-shadow:0 24px 70px rgba(0,0,0,.22);
  backdrop-filter:blur(14px);
}

th{
  background:linear-gradient(90deg,rgba(99,102,241,.38),rgba(56,189,248,.16));
  color:#e0e7ff;
  padding:14px;
  text-align:left;
  font-size:12px;
  text-transform:uppercase;
  letter-spacing:.08em;
  border-bottom:1px solid rgba(148,163,184,.18);
}

td{
  padding:14px;
  border-bottom:1px solid rgba(148,163,184,.12);
  font-size:14px;
  vertical-align:top;
  color:#e5e7eb;
}

tr:hover td{
  background:rgba(99,102,241,.08);
}

.muted{color:var(--muted)}

.btn{
  display:inline-block;
  border:0;
  cursor:pointer;
  padding:9px 13px;
  border-radius:12px;
  background:linear-gradient(135deg,var(--primary),var(--secondary));
  color:white;
  text-decoration:none;
  font-weight:800;
  box-shadow:0 12px 30px rgba(99,102,241,.25);
}

.btn:hover{
  transform:translateY(-1px);
  filter:brightness(1.08);
}

.status-pill{
  display:inline-block;
  padding:7px 11px;
  border-radius:999px;
  font-weight:900;
  font-size:13px;
}

.risk-low{background:rgba(34,197,94,.16);color:#86efac;border:1px solid rgba(34,197,94,.35)}
.risk-mid{background:rgba(245,158,11,.16);color:#fcd34d;border:1px solid rgba(245,158,11,.35)}
.risk-high{background:rgba(239,68,68,.16);color:#fca5a5;border:1px solid rgba(239,68,68,.35)}

#dealModal,#clientModal{
  background:
    radial-gradient(circle at top right, rgba(99,102,241,.2), transparent 28%),
    rgba(15,23,42,.97) !important;
  color:var(--text);
  border-left:1px solid rgba(56,189,248,.5);
  box-shadow:-30px 0 90px rgba(0,0,0,.55) !important;
}

#dealModal h2,#clientModal h2,
#dealModal h3,#clientModal h3{
  color:white;
}

#dealModal p,#clientModal p{
  color:#e5e7eb;
}

#dealModal button,#clientModal button{
  color:white;
}

#dealModal img,#clientModal img{
  box-shadow:0 18px 60px rgba(0,0,0,.35);
}

.tabs{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin:0 0 22px 0;
}

.tab-btn{
  border:1px solid rgba(148,163,184,.22);
  background:rgba(15,23,42,.72);
  color:#e5e7eb;
  padding:10px 14px;
  border-radius:14px;
  cursor:pointer;
  font-weight:800;
}

.tab-btn.active{
  background:linear-gradient(135deg,var(--primary),var(--secondary));
  color:#fff;
  box-shadow:0 12px 30px rgba(99,102,241,.25);
}

.tab-section{
  display:none;
}

.tab-section.active{
  display:block;
}

