function showTab(name, btn){
  document.querySelectorAll(".tab-section").forEach(x => x.classList.remove("active"));
  document.querySelectorAll(".tab-btn").forEach(x => x.classList.remove("active"));

  const section = document.getElementById("tab-" + name);
  if(section) section.classList.add("active");

  if(btn) btn.classList.add("active");

  localStorage.setItem("dispatcher_tab", name);
}

function restoreTab(){
  const saved = localStorage.getItem("dispatcher_tab") || "overview";
  const btn = Array.from(document.querySelectorAll(".tab-btn")).find(b => b.getAttribute("onclick") && b.getAttribute("onclick").includes("'" + saved + "'"));
  showTab(saved, btn);
}

function trustLabel(score){
  score = Number(score || 50);
  if(score >= 80) return ["🟢 Надёжный", "risk-low"];
  if(score >= 50) return ["🟡 Новый / средний риск", "risk-mid"];
  return ["🔴 Высокий риск", "risk-high"];
}

