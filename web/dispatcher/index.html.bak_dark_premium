<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <title>Кабинет диспетчера — Dalnoboy</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
:root{
  --bg:#eef2f7;
  --dark:#07182f;
  --blue:#0b5ed7;
  --cyan:#00a3ff;
  --green:#16a34a;
  --red:#dc2626;
  --yellow:#f59e0b;
  --card:#ffffff;
  --line:#e5e7eb;
  --text:#111827;
  --muted:#64748b;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:Arial,Helvetica,sans-serif;
  background:var(--bg);
  color:var(--text);
}

header{
  background:linear-gradient(90deg,#07182f,#0b3b78);
  color:white;
  padding:18px 26px;
  display:flex;
  align-items:center;
  gap:14px;
  border-bottom:4px solid var(--cyan);
}

header img{
  width:58px;
  height:58px;
  border-radius:16px;
  object-fit:cover;
  background:white;
}

.wrap{
  padding:22px;
  max-width:1500px;
  margin:0 auto;
}

.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(190px,1fr));
  gap:16px;
  margin-bottom:24px;
}

.card{
  background:var(--card);
  border-radius:18px;
  padding:18px;
  box-shadow:0 8px 24px rgba(15,23,42,.08);
  border-top:4px solid var(--blue);
}

.card .num{
  font-size:30px;
  font-weight:900;
  margin-top:10px;
  color:var(--dark);
}

h2{
  margin:30px 0 12px;
  font-size:22px;
  color:var(--dark);
  border-left:6px solid var(--blue);
  padding-left:10px;
}

table{
  width:100%;
  border-collapse:separate;
  border-spacing:0;
  background:white;
  border-radius:18px;
  overflow:hidden;
  box-shadow:0 8px 24px rgba(15,23,42,.07);
}

th{
  background:#0b3b78;
  color:white;
  padding:13px;
  text-align:left;
  font-size:13px;
  text-transform:uppercase;
  letter-spacing:.04em;
}

td{
  padding:13px;
  border-bottom:1px solid var(--line);
  font-size:14px;
  vertical-align:top;
}

tr:hover td{
  background:#f8fbff;
}

.muted{color:var(--muted)}

.btn{
  display:inline-block;
  border:0;
  cursor:pointer;
  padding:8px 12px;
  border-radius:10px;
  background:var(--blue);
  color:white;
  text-decoration:none;
  font-weight:700;
}

.btn:hover{filter:brightness(.95)}

.status-pill{
  display:inline-block;
  padding:6px 10px;
  border-radius:999px;
  font-weight:800;
  font-size:13px;
}

.risk-low{background:#dcfce7;color:#166534}
.risk-mid{background:#fef3c7;color:#92400e}
.risk-high{background:#fee2e2;color:#991b1b}

#dealModal,#clientModal{
  border-left:6px solid var(--cyan);
}

#dealModal h2,#clientModal h2{
  color:var(--dark);
}
</style>
</head>
<body>
<header><img src="/assets/logo.png" style="width:54px;height:54px;border-radius:14px;object-fit:cover"><div>Dalnoboy Bros<br><span style="font-size:13px;font-weight:400;color:#cbd5e1">Безопасные перевозки и сделки</span></div></header>

<div id="app" class="wrap">
  Загрузка...
</div>

<script>
const allowedBrowserIds = [8612087868, 8253347001];

const params = new URLSearchParams(location.search);
const devId = Number(params.get("dev"));

if (!allowedBrowserIds.includes(devId)) {
  document.getElementById("app").innerHTML = `
    <div class="bad">
      <h2>Доступ закрыт</h2>
      <p>Откройте кабинет по персональной ссылке диспетчера.</p>
    </div>
  `;
  throw new Error("no dispatcher access");
}

function money(v) {
  if (!v) return "-";
  return Number(v).toLocaleString("ru-RU") + " ₽";
}

async function load() {
  const [cargoRes, trucksRes, dealsRes, disputesRes, clientsRes] = await Promise.all([
    fetch("/api/cargo/open"),
    fetch("/api/trucks/active"),
    fetch("/api/deals"),
    fetch("/api/disputes"),
    fetch("/api/dispatcher/clients")
  ]);

  const cargo = await cargoRes.json();
  const trucks = await trucksRes.json();
  const deals = await dealsRes.json();
  const disputes = await disputesRes.json();
  const clients = await clientsRes.json();

  const cargoItems = cargo.items || [];
  const truckItems = trucks.items || [];
  const dealItems = deals.items || [];
  const disputeItems = disputes.items || [];
  const clientItems = clients.items || [];

  const profitTotal = dealItems.reduce((sum,d) => sum + Number(d.dispatcher_profit || 0), 0);
  const today = new Date().toISOString().slice(0,10);
  const profitToday = dealItems
    .filter(d => String(d.created_at || "").slice(0,10) === today)
    .reduce((sum,d) => sum + Number(d.dispatcher_profit || 0), 0);

  document.getElementById("app").innerHTML = `
    <div class="cards">
      <div class="card">📦 Открытые грузы<div class="num">${cargoItems.length}</div></div>
      <div class="card">🚚 Активные машины<div class="num">${truckItems.length}</div></div>
      <div class="card">🤝 Сделки<div class="num">${dealItems.length}</div></div>
      <div class="card">💰 Прибыль сегодня<div class="num">${money(profitToday)}</div></div>
      <div class="card">💼 Прибыль всего<div class="num">${money(profitTotal)}</div></div>
      <div class="card">⚠️ Споры<div class="num">${disputeItems.length}</div></div>
      <div class="card">👥 Клиенты<div class="num">${clientItems.length}</div></div>
    </div>

    <h2>📦 Грузы</h2>
    <table>
      <thead>
        <tr>
          <th>ID</th><th>Маршрут</th><th>Цена</th><th>Ставка</th><th>Статус</th>
        </tr>
      </thead>
      <tbody>
        ${cargoItems.map(c => `
          <tr>
            <td>#${c.id}</td>
            <td>${c.from_city || "-"} → ${c.to_city || "-"}</td>
            <td>${money(c.price_amount)}</td>
            <td>${c.rate_per_km ? c.rate_per_km + " ₽/км" : "-"}</td>
            <td>${c.status || "open"}</td>
          </tr>
        `).join("") || `<tr><td colspan="5" class="muted">Грузов пока нет</td></tr>`}
      </tbody>
    </table>

    <h2>🚚 Машины</h2>
    <table>
      <thead>
        <tr>
          <th>ID</th><th>Перевозчик</th><th>Статус</th><th>Последняя активность</th>
        </tr>
      </thead>
      <tbody>
        ${truckItems.map(t => `
          <tr>
            <td>#${t.id}</td>
            <td>Перевозчик #${t.driver_id}</td>
            <td>${t.online_status || "-"}</td>
            <td>${t.location_updated_at ? new Date(t.location_updated_at).toLocaleString("ru-RU") : "-"}</td>
          </tr>
        `).join("") || `<tr><td colspan="4" class="muted">Активных машин пока нет</td></tr>`}
      </tbody>
    </table>

    <h2>🤝 Сделки</h2>
    <table>
      <thead>
        <tr><th>ID</th><th>Груз</th><th>Машина</th><th>Статус</th><th>Действие</th></tr>
      </thead>
      <tbody>
        ${dealItems.map(d => `
          <tr>
            <td>#${d.id}</td>
            <td>#${d.cargo_id} · ${d.from_city || "-"} → ${d.to_city || "-"}</td>
            <td>${d.driver_name ? "Перевозчик: " + d.driver_name : "Машина #" + (d.truck_id || "-")}</td>
            <td>${d.status || "-"}</td>
            <td><button class="btn" onclick="openDeal(${d.id})">👁 Открыть</button></td>
          </tr>
        `).join("") || `<tr><td colspan="4" class="muted">Сделок пока нет</td></tr>`}
      </tbody>
    </table>

    <h2>👥 Клиенты</h2>
    <table>
      <thead>
        <tr><th>ID</th><th>Клиент</th><th>Тип</th><th>Доверие</th><th>Комиссия</th><th>Статус</th><th>Действие</th></tr>
      </thead>
      <tbody>
        ${clientItems.map(c => `
          <tr>
            <td>#${c.id}</td>
            <td>${c.full_name || "Клиент #" + c.client_user_id}</td>
            <td>${c.client_type || c.role || "-"}</td>
            <td>${c.trust_score || 50}/100</td>
            <td>${c.commission_percent || 0}%</td>
            <td>${c.status || "-"}</td>
            <td><button class="btn" onclick="openClient(${c.id})">👁 Открыть</button></td>
          </tr>
        `).join("") || `<tr><td colspan="6" class="muted">Клиентов пока нет</td></tr>`}
      </tbody>
    </table>

    <h2>⚖️ Споры</h2>
    <table>
      <thead>
        <tr><th>ID</th><th>Сделка</th><th>Причина</th><th>Открыл</th><th>Статус</th></tr>
      </thead>
      <tbody>
        ${disputeItems.map(x => `
          <tr>
            <td>#${x.id}</td>
            <td>Сделка #${x.deal_id}<br><span class="muted">${(x.from_city||"-").split(",")[0]} → ${(x.to_city||"-").split(",")[0]}</span></td>
            <td>${x.reason || "-"}</td>
            <td>${x.opened_by_name || "Пользователь #" + (x.opened_by || "-")}</td>
            <td>${x.status || "-"}</td>
          </tr>
        `).join("") || `<tr><td colspan="5" class="muted">Споров пока нет</td></tr>`}
      </tbody>
    </table>

    <p style="margin-top:24px;">
      <a class="btn" href="/?dev=${devId}">🗺 Открыть карту</a>
    </p>
  `;
}

load().catch(e => {
  document.getElementById("app").innerHTML =
    "<div class='bad'><h2>Ошибка загрузки</h2><p>" + e.message + "</p></div>";
});


function trustLabel(score){
  score = Number(score || 50);
  if(score >= 80) return ["🟢 Надёжный", "risk-low"];
  if(score >= 50) return ["🟡 Новый / средний риск", "risk-mid"];
  return ["🔴 Высокий риск", "risk-high"];
}

function openClient(id){
  const c = clientItems.find(x => Number(x.id) === Number(id));
  if(!c){
    alert("Клиент не найден");
    return;
  }

  const [label, cls] = trustLabel(c.trust_score);

  let box=document.getElementById("clientModal");
  if(box) box.remove();

  box=document.createElement("div");
  box.id="clientModal";
  box.style=`
    position:fixed;
    right:0;
    top:0;
    width:480px;
    height:100%;
    background:white;
    z-index:99999;
    overflow:auto;
    box-shadow:-10px 0 30px rgba(0,0,0,.2);
    padding:24px;
  `;

  box.innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:center">
      <h2>👥 Клиент #${c.id}</h2>
      <button onclick="clientModal.remove()">✖</button>
    </div>

    <div style="display:flex;align-items:center;gap:12px;margin:18px 0">
      <img src="/assets/logo.png" style="width:64px;height:64px;border-radius:16px;object-fit:cover">
      <div>
        <b style="font-size:20px">${c.full_name || "Клиент #" + c.client_user_id}</b><br>
        <span class="muted">Dalnoboy Bros · CRM диспетчера</span>
      </div>
    </div>

    <p><b>Тип клиента</b><br>${c.client_type || c.role || "-"}</p>

    <p><b>Статус</b><br>${c.status || "-"}</p>

    <p><b>Комиссия диспетчера</b><br>${c.commission_percent || 0}%</p>

    <div style="background:#f3f4f6;padding:14px;border-radius:12px;margin:14px 0">
      <h3 style="margin-top:0">⭐ Индекс доверия</h3>
      <p><span class="status-pill ${cls}">${label}</span></p>
      <p style="font-size:28px;font-weight:800;margin:8px 0">${c.trust_score || 50}/100</p>
      <p class="muted">Контакты и документы скрыты. Пользователи видят только статус проверки и рейтинг.</p>
    </div>

    <div style="background:#ecfdf5;padding:14px;border-radius:12px;margin:14px 0">
      <h3 style="margin-top:0">🛡 Защита данных</h3>
      <p>✅ Персональные данные не раскрываются</p>
      <p>✅ Документы доступны только администратору</p>
      <p>✅ Контакты открываются только по правилам безопасной сделки</p>
    </div>

    <hr>

    <h3>📋 Что дальше</h3>
    <p>Здесь позже появятся сделки клиента, споры, документы и доход диспетчера по этому клиенту.</p>
  `;

  document.body.append(box);
}

async function setDealStatus(id,status){
  await fetch("/api/deal/"+id+"/status",{
    method:"POST",
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({status})
  });

  openDeal(id);
  location.reload();
}

async function openDeal(id){

const res=await fetch("/api/deal/"+id);
const data=await res.json();

const auditRes = await fetch("/api/deal/" + id + "/audit");
const auditData = await auditRes.json();
const auditItems = auditData.items || [];

const docsRes = await fetch("/api/deal/" + id + "/documents");
const docsData = await docsRes.json();
const docItems = docsData.items || [];

if(!data.success){
alert("Сделка не найдена");
return;
}

const d=data.deal;
const history=data.history||[];

let box=document.getElementById("dealModal");

if(box) box.remove();

box=document.createElement("div");

box.id="dealModal";

box.style=`
position:fixed;
right:0;
top:0;
width:520px;
height:100%;
background:white;
z-index:99999;
overflow:auto;
box-shadow:-10px 0 30px rgba(0,0,0,.2);
padding:24px;
`;

box.innerHTML=`
<div style="display:flex;justify-content:space-between">

<h2>🤝 Сделка #${d.id}</h2>

<button onclick="dealModal.remove()">✖</button>

</div>

<p><b>Маршрут</b><br>
${(d.from_city||"-").split(",")[0]}
→
${(d.to_city||"-").split(",")[0]}</p>

<p><b>Цена груза</b><br>
${money(d.price_amount)}</p>

<div style="background:#f3f4f6;padding:14px;border-radius:12px;margin:14px 0">
  <h3 style="margin-top:0">💰 Финансы сделки</h3>
  <p><b>Клиент платит:</b> ${money(d.client_price)}</p>
  <p><b>Перевозчику:</b> ${money(d.carrier_price)}</p>
  <p><b>Прибыль диспетчера:</b> ${money(d.dispatcher_profit)}</p>
</div>

<p><b>Перевозчик</b><br>
${d.driver_name||"-"}</p>

${
d.truck_photo_url
?
`<img src="${d.truck_photo_url}" style="
  width:100%;
  max-height:260px;
  object-fit:cover;
  border-radius:16px;
  margin:10px 0;
  box-shadow:0 2px 12px rgba(0,0,0,.15);
">`
:
`<div style="
  background:#f3f4f6;
  padding:18px;
  border-radius:14px;
  margin:10px 0;
  text-align:center;
  color:#666;
">Фото машины пока нет</div>`
}

<p><b>Индекс доверия перевозчика</b><br>
${d.driver_trust_score || 50} / 100</p>

<p><b>Статус</b><br>
<span style="
padding:6px 12px;
background:#eef4ff;
border-radius:10px">
${d.status}
</span></p>

<div style="background:#ecfdf5;padding:14px;border-radius:12px;margin:14px 0">
  <h3 style="margin-top:0">🛡 Безопасная сделка</h3>
  <p><b>Статус:</b> ${d.safe_deal_status || "draft"}</p>
  <p>📦 Заказчик: ${d.shipper_confirmed ? "✅ подтверждено" : "❌ нет"}</p>
  <p>🚚 Перевозчик: ${d.carrier_confirmed ? "✅ подтверждено" : "❌ нет"}</p>
  <p>👨‍💼 Диспетчер: ${d.dispatcher_confirmed ? "✅ подтверждено" : "❌ нет"}</p>
  <p>💳 Оплата: ${d.payment_status || "pending"}</p>
</div>

<div style="display:flex;gap:8px;flex-wrap:wrap">

<button class="btn"
onclick="setDealStatus(${d.id},'in_progress')">

📍 В пути

</button>

<button class="btn"

onclick="setDealStatus(${d.id},'done')">

✅ Доставлено

</button>

<button class="btn"

style="background:#c62828"

onclick="setDealStatus(${d.id},'cancelled')">

❌ Отменить

</button>

</div>

<hr>

<h3>📄 Документы сделки</h3>

${
docItems.length
?
docItems.map(doc=>`
<div style="padding:10px;border-bottom:1px solid #eee">
  <b>${doc.file_name || doc.doc_type}</b><br>
  Тип: ${doc.doc_type}<br>
  Загрузил: ${doc.uploaded_by_name || "Пользователь #" + (doc.uploaded_by || "-")}<br>
  <small>${new Date(doc.created_at).toLocaleString("ru-RU")}</small>
</div>
`).join("")
:
"<p>Документов пока нет</p>"
}

<hr>

<h3>📜 Журнал действий</h3>

${
auditItems.length
?
auditItems.map(a=>`
<div style="
padding:10px;
border-bottom:1px solid #eee">

<b>${a.full_name || "Пользователь #" + (a.user_id || "-")}</b><br>
${a.action}<br>
${a.old_value ? a.old_value + " → " : ""}${a.new_value || ""}

<br>

<small>
${new Date(a.created_at).toLocaleString("ru-RU")}
</small>

</div>
`).join("")
:
"<p>Журнал пуст</p>"
}

<hr>

<h3>История статусов</h3>

${
history.length
?
history.map(x=>`
<div style="
padding:10px;
border-bottom:1px solid #eee">

${x.status}

<br>

<small>

${new Date(x.created_at).toLocaleString("ru-RU")}

</small>

</div>
`).join("")
:
"<p>Пока пусто</p>"
}
`;

document.body.append(box);

}
</script>
</body>
</html>
